{
  "plan_id": "overthinking-genz-nyc-15seg",
  "segments": [
    {"segment_id":"seg-1","text":"Midnight in Queens. You're in bed, eyes open, replaying one awkward moment from today.","slot_id":"slot-01","primary_atom_id":"atom-001","atom_refs":[{"atom_id":"atom-001","weight":1.0,"role":"primary"}]},
    {"segment_id":"seg-2","text":"Your brain says it is preparing you. Your body says it's still under threat.","slot_id":"slot-02","primary_atom_id":"atom-002","atom_refs":[{"atom_id":"atom-002","weight":1.0,"role":"primary"}]},
    {"segment_id":"seg-3","text":"Your jaw is tight. Your chest is shallow. Your shoulders are up by your ears.","slot_id":"slot-03","primary_atom_id":"atom-003","atom_refs":[{"atom_id":"atom-003","weight":1.0,"role":"primary"}]},
    {"segment_id":"seg-4","text":"You scroll for relief and find more noise. The loop gets louder.","slot_id":"slot-04","primary_atom_id":"atom-004","atom_refs":[{"atom_id":"atom-004","weight":1.0,"role":"primary"}]},
    {"segment_id":"seg-5","text":"Pause. Put both feet on the floor. Feel the contact points.","slot_id":"slot-05","primary_atom_id":"atom-005","atom_refs":[{"atom_id":"atom-005","weight":1.0,"role":"primary"}]},
    {"segment_id":"seg-6","text":"Name five things you can see in the room right now.","slot_id":"slot-06","primary_atom_id":"atom-006","atom_refs":[{"atom_id":"atom-006","weight":1.0,"role":"primary"}]},
    {"segment_id":"seg-7","text":"Exhale longer than you inhale, three times in a row.","slot_id":"slot-07","primary_atom_id":"atom-007","atom_refs":[{"atom_id":"atom-007","weight":1.0,"role":"primary"}]},
    {"segment_id":"seg-8","text":"Open notes and write your top worry as one sentence.","slot_id":"slot-08","primary_atom_id":"atom-008","atom_refs":[{"atom_id":"atom-008","weight":1.0,"role":"primary"}]},
    {"segment_id":"seg-9","text":"Write one action for tomorrow morning, not tonight.","slot_id":"slot-09","primary_atom_id":"atom-009","atom_refs":[{"atom_id":"atom-009","weight":1.0,"role":"primary"}]},
    {"segment_id":"seg-10","text":"Write the second worry and one action. Keep it small and real.","slot_id":"slot-10","primary_atom_id":"atom-010","atom_refs":[{"atom_id":"atom-010","weight":1.0,"role":"primary"}]},
    {"segment_id":"seg-11","text":"Write the third worry and one action. Then close the app.","slot_id":"slot-11","primary_atom_id":"atom-011","atom_refs":[{"atom_id":"atom-011","weight":1.0,"role":"primary"}]},
    {"segment_id":"seg-12","text":"Your mind does not need certainty. It needs a trusted next step.","slot_id":"slot-12","primary_atom_id":"atom-012","atom_refs":[{"atom_id":"atom-012","weight":1.0,"role":"primary"}]},
    {"segment_id":"seg-13","text":"You are not failing. You're overloaded in a city that never pauses.","slot_id":"slot-13","primary_atom_id":"atom-013","atom_refs":[{"atom_id":"atom-013","weight":1.0,"role":"primary"}]},
    {"segment_id":"seg-14","text":"Say this once: I can handle tomorrow, tomorrow.","slot_id":"slot-14","primary_atom_id":"atom-014","atom_refs":[{"atom_id":"atom-014","weight":1.0,"role":"primary"}]},
    {"segment_id":"seg-15","text":"One breath out. One release. Rest is now allowed.","slot_id":"slot-15","primary_atom_id":"atom-015","atom_refs":[{"atom_id":"atom-015","weight":1.0,"role":"primary"}]}
  ]
}
