{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://phoenix/schemas/release/advisory_report_v1.schema.json",
  "title": "Advisory report (per-brand packet)",
  "description": "advisory_report.json in each brand packet: non-blocking issues only.",
  "type": "object",
  "required": ["schema_version", "issues"],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0" },
    "week": { "type": "string" },
    "brand_id": { "type": "string" },
    "issues": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["schema_version", "issue_id", "severity", "reason", "source"],
        "properties": {
          "schema_version": { "type": "string" },
          "issue_id": { "type": "string" },
          "severity": { "type": "string", "enum": ["info", "warn", "critical"] },
          "reason": { "type": "string" },
          "source": { "type": "string" },
          "plan_id": { "type": "string" },
          "wave_id": { "type": "string" },
          "nearest_neighbors": { "type": "array" },
          "created_at": { "type": "string" },
          "details": { "type": "object" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
