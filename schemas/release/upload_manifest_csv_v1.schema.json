{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://phoenix/schemas/release/upload_manifest_csv_v1.schema.json",
  "title": "Upload manifest CSV contract",
  "description": "Contract for upload_manifest.csv: required headers and row shape after CSV->JSON transform. One row per book.",
  "schema_version": "1.0",

  "required_headers": [
    "plan_id",
    "title",
    "subtitle",
    "description",
    "keywords",
    "category",
    "series_id",
    "installment_number",
    "price",
    "brand_id",
    "topic_id",
    "persona_id",
    "locale"
  ],

  "row_schema": {
    "type": "object",
    "required": ["plan_id", "brand_id"],
    "properties": {
      "plan_id": { "type": "string" },
      "title": { "type": "string" },
      "subtitle": { "type": "string" },
      "description": { "type": "string" },
      "keywords": { "type": "string" },
      "category": { "type": "string" },
      "series_id": { "type": "string" },
      "installment_number": { "type": ["string", "integer", "null"] },
      "price": { "type": "string" },
      "brand_id": { "type": "string" },
      "topic_id": { "type": "string" },
      "persona_id": { "type": "string" },
      "locale": { "type": "string" }
    },
    "additionalProperties": true
  }
}
