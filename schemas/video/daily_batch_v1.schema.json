{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "daily_batch_v1",
  "description": "Daily batch index written by the Distribution Writer after all R2 uploads succeed. Partner reads only this file to discover video paths. Wipe script reads this to verify counts before deletion.",
  "type": "object",
  "required": [
    "schema_version",
    "batch_date",
    "batch_id",
    "created_at",
    "long_form",
    "shorts",
    "long_form_count",
    "shorts_count"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "batch_date": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
      "description": "ISO date (YYYY-MM-DD) for this batch."
    },
    "batch_id": {
      "type": "string",
      "description": "Unique batch identifier, e.g. batch-2026-03-08-001."
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp when daily_batch.json was written."
    },
    "long_form": {
      "type": "array",
      "items": { "$ref": "#/$defs/video_entry" },
      "description": "All long-form videos in this batch."
    },
    "shorts": {
      "type": "array",
      "items": { "$ref": "#/$defs/video_entry" },
      "description": "All short-form videos in this batch."
    },
    "long_form_count": {
      "type": "integer",
      "minimum": 0,
      "description": "Must equal len(long_form). Partner and wipe script verify this."
    },
    "shorts_count": {
      "type": "integer",
      "minimum": 0,
      "description": "Must equal len(shorts). Partner and wipe script verify this."
    }
  },
  "$defs": {
    "video_entry": {
      "type": "object",
      "required": ["video_id", "r2_prefix", "distribution_manifest_key"],
      "additionalProperties": true,
      "properties": {
        "video_id": {
          "type": "string"
        },
        "plan_id": {
          "type": "string"
        },
        "r2_prefix": {
          "type": "string",
          "description": "R2 key prefix, e.g. 2026-03-08/long/video-001/"
        },
        "distribution_manifest_key": {
          "type": "string",
          "description": "R2 key to distribution_manifest.json for this video."
        },
        "title": {
          "type": "string"
        },
        "primary_asset_ids": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}
