{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://phoenix/schemas/video/shot_plan_v1.schema.json",
  "title": "Shot plan v1",
  "description": "One visual story per plan: shot_id, visual_intent, duration_s, thumbnail_candidate, prompt_bundle. Output of Shot Planner.",
  "type": "object",
  "required": ["plan_id", "shots"],
  "additionalProperties": true,
  "properties": {
    "plan_id": { "type": "string", "description": "Content plan identifier" },
    "content_type": { "type": "string" },
    "config_hash": { "type": "string" },
    "shots": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["shot_id", "segment_id", "visual_intent", "duration_s", "thumbnail_candidate"],
        "additionalProperties": true,
        "properties": {
          "shot_id": { "type": "string" },
          "segment_id": { "type": "string" },
          "visual_intent": { "type": "string" },
          "aspect_ratio": { "type": "string", "enum": ["16:9", "9:16", "1:1"] },
          "duration_s": { "type": "number", "minimum": 0 },
          "thumbnail_candidate": { "type": "boolean" },
          "prompt_bundle": {
            "type": "object",
            "properties": {
              "style": { "type": "string" },
              "motion": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
